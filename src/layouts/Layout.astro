---
import "../styles/global.css";
const { title = "Luna Martello — Hospitalidad & Web" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Luna Martello — Superanfitriona Airbnb y desarrolladora web freelance. Busco oportunidades part-time en hotelería en Buenos Aires."
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav id="navbar">
      <div class="nav-inner container">
        <a class="nav-logo" href="#index">
          <img src="/Lunam.png" alt="Luna Martello" height="65" />
        </a>
        <button class="hamburger" id="hamburger" aria-label="Menú">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="nav-links">
          <li><a href="#index" class="nav-link">Inicio</a></li>
          <li><a href="#about" class="nav-link">Sobre mí</a></li>
          <li><a href="#experiencia" class="nav-link">Experiencia</a></li>
          <li>
            <a href="#contacto" class="nav-link btn btn-primary nav-cta"
              >Contacto</a
            >
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/ayelenbusca/"
              target="_blank"
              rel="noopener"
              class="nav-link nav-linkedin"
              aria-label="LinkedIn"
            >
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                width="22"
                height="22"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="container footer-inner">
        <span class="mono footer-copy">© 2026 Luna Martello · Argentina</span>
        <a
          href="/Luna-MartelloCV.pdf"
          download="Luna_Martello_CV.pdf"
          class="btn-cv"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            width="15"
            height="15"
          >
            <path
              d="M12 15V3m0 12l-4-4m4 4l4-4M2 17l.621 2.485A2 2 0 004.561 21h14.878a2 2 0 001.94-1.515L22 17"
            ></path>
          </svg>
          Descargar CV en PDF
        </a>
      </div>
    </footer>
  </body>
</html>

<style>
  /* ── Nav ── */
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: box-shadow 0.3s;
    background: var(--cream);
  }

  #navbar.scrolled {
    box-shadow: 0 1px 0 var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .nav-logo {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--bark);
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--bark);
    transition: color 0.2s;
    position: relative;
  }

  .nav-link:not(.btn):not(.nav-linkedin)::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--amber);
    transition: width 0.25s ease;
  }
  .nav-link:not(.btn):not(.nav-linkedin):hover::after {
    width: 100%;
  }

  .nav-linkedin {
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  .nav-linkedin:hover {
    color: #0077b5;
  }

  .btn-linkedin {
    padding: 9px 20px;
    font-size: 0.85rem;
    color: var(--bark) !important;
    border: 1px solid var(--border) !important;
    border-radius: 999px;
    background: transparent;
    transition:
      border-color 0.2s,
      background 0.2s,
      color 0.2s;
  }
  .btn-linkedin:hover {
    border-color: #0077b5 !important;
    color: #0077b5 !important;
    background: transparent;
  }

  .nav-cta {
    padding: 9px 20px;
    font-size: 0.85rem;
    color: #fff !important;
  }
  .nav-cta:hover {
    background: var(--bark) !important;
    color: #fff !important;
  }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--bark);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    background: var(--sand);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .btn-cv {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono, "JetBrains Mono", monospace);
    font-size: 0.8rem;
    color: var(--bark);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 8px 18px;
    background: var(--cream);
    text-decoration: none;
    transition:
      border-color 0.2s,
      background 0.2s,
      color 0.2s;
    letter-spacing: 0.02em;
  }
  .btn-cv:hover {
    border-color: var(--amber);
    background: var(--amber);
    color: #fff;
  }
  .btn-cv svg {
    flex-shrink: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }
    .nav-logo img {
      height: 58px;
    }
    .nav-links {
      position: fixed;
      top: 68px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: var(--cream);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0 1.5rem;
      transform: translateY(-120%);
      opacity: 0;
      transition:
        transform 0.35s ease,
        opacity 0.3s;
      pointer-events: none;
    }
    .nav-links.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: all;
    }
    .nav-links li {
      width: 100%;
      text-align: center;
    }
    .nav-link {
      display: block;
      padding: 12px 0;
      font-size: 1rem;
      transition: color 0.2s;
    }
    .nav-link:not(.btn)::after {
      display: none;
    }
    .nav-link:not(.btn):hover,
    .nav-link:not(.btn):active {
      color: var(--amber);
    }
    .btn-linkedin {
      border: none !important;
      border-radius: 0;
      padding: 12px 0;
      font-size: 1rem;
      color: var(--bark) !important;
      background: transparent;
    }
    .nav-linkedin {
      display: flex;
      justify-content: center;
      padding: 12px 0;
    }
    .nav-cta {
      margin: 0.5rem auto 0;
      display: inline-flex;
      padding: 14px 40px;
    }
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>

<script>
  const nav = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    nav?.classList.toggle("scrolled", window.scrollY > 20);
  });

  const btn = document.getElementById("hamburger");
  const links = document.getElementById("nav-links");
  btn?.addEventListener("click", () => {
    links?.classList.toggle("open");
  });

  document.querySelectorAll(".nav-link").forEach((l) => {
    l.addEventListener("click", () => links?.classList.remove("open"));
  });
</script>
