---

---

<section id="index" class="hero">
  <div class="hero-bg-pattern"></div>
  <div class="container hero-inner">
    <div class="hero-text fade-up">
      <div class="hero-badges">
        <span class="neon-tag">✦ Disponible para trabajar</span>
        <span class="availability-badge">Part-time · Francos </span>
      </div>
      <h1 class="display hero-title delay-1 fade-up">
        Hospitalidad<br />con alma<br /><em>y código.</em>
      </h1>
      <p class="hero-sub delay-2 fade-up">
        Soy <strong>Luna Martello</strong> — superanfitriona Airbnb con <span
          class="highlight">4.92 ★</span
        >
        y más de 62 reseñas. Busco sumarme a equipos de hotelería en modalidad part-time
        o cubriendo francos.
      </p>
      <div class="hero-actions delay-3 fade-up">
        <a href="#contacto" class="btn btn-primary">Contactame →</a>
        <a href="#experiencia" class="btn btn-outline">Ver experiencia</a>
      </div>
    </div>

    <div class="hero-photo-wrap delay-4 fade-up">
      <div class="photo-frame">
        <img src="/tu-foto.jpg" alt="Luna Martello" />
        <div class="stat-chip chip-1">
          <span class="chip-num display">4.92</span>
          <span class="chip-label mono">★ promedio</span>
        </div>
        <div class="stat-chip chip-2">
          <span class="chip-num display">62+</span>
          <span class="chip-label mono">reseñas</span>
        </div>
        <div class="stat-chip chip-3">
          <span class="mono" style="font-size:0.7rem; font-weight:700;"
            >Superanfitriona</span
          >
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-hint mono">scroll ↓</div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 60% 70% at 80% 50%,
        rgba(200, 129, 58, 0.08) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 40% 40% at 10% 80%,
        rgba(168, 224, 99, 0.06) 0%,
        transparent 60%
      );
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .availability-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 3px;
    letter-spacing: 0.05em;
  }

  .hero-title {
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    line-height: 1.1;
    color: var(--bark);
    margin-bottom: 1.5rem;
  }
  .hero-title em {
    color: var(--amber);
    font-style: italic;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 480px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }
  .hero-sub strong {
    color: var(--bark);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Photo */
  .hero-photo-wrap {
    position: relative;
  }

  .photo-frame {
    position: relative;
    width: 100%;
    max-width: 380px;
    margin: 0 auto;
  }

  .photo-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: linear-gradient(145deg, var(--sand), #e8dece);
    border-radius: 200px 200px 120px 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed var(--border);
    color: var(--muted);
    font-size: 0.8rem;
  }

  .photo-frame img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: 200px 200px 120px 120px;
  }

  .stat-chip {
    position: absolute;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .chip-num {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--bark);
    line-height: 1;
  }
  .chip-label {
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  .chip-1 {
    bottom: 20%;
    left: -28px;
  }
  .chip-2 {
    top: 18%;
    right: -20px;
  }
  .chip-3 {
    bottom: 8%;
    right: 10%;
    background: var(--neon);
    border-color: var(--neon-dim);
    color: var(--warm-dark);
    border-radius: 6px;
    padding: 6px 12px;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.12em;
    animation: bob 2s ease-in-out infinite;
  }

  @keyframes bob {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(6px);
    }
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-sub {
      margin: 0 auto 2.5rem;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-photo-wrap {
      order: -1;
    }
    .photo-frame {
      max-width: 260px;
    }
    .chip-1 {
      left: -10px;
    }
    .chip-2 {
      right: -10px;
    }
  }
</style>
