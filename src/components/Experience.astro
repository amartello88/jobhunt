---

---

<section id="experiencia" class="section experiencia">
  <div class="container">
    <p class="section-label">Experiencia</p>
    <h2 class="section-title">
      Lo que traigo<br />a cada <span class="highlight">equipo.</span>
    </h2>
    <hr class="divider" />

    <div class="exp-grid">
      <!-- Airbnb card grande -->
      <div class="exp-card exp-main">
        <div class="exp-card-top">
          <div class="exp-icon">🏡</div>
          <div>
            <h3 class="exp-role display">Superanfitriona Airbnb</h3>
            <p class="exp-company mono">Gestión propia · Airbnb</p>
          </div>
          <div class="exp-rating">
            <span class="rating-num display">4.92</span>
            <span class="mono" style="font-size:0.7rem; color:var(--muted);"
              >★ 62+ reseñas</span
            >
          </div>
        </div>
        <p class="exp-desc">
          Gestión integral de propiedad: atención al huésped, comunicación
          proactiva, limpieza profunda entre estadías, mantenimiento,
          optimización de precios y calendario, resolución de imprevistos.
          Superanfitriona por consistencia en calidad y respuesta.
        </p>
        <div class="exp-tags">
          <span class="exp-tag">Atención al huésped</span>
          <span class="exp-tag">Gestión de reservas</span>
          <span class="exp-tag">Check-in / Check-out</span>
          <span class="exp-tag">Limpieza profunda</span>
          <span class="exp-tag">Comunicación multicultural</span>
          <span class="exp-tag">Resolución de problemas</span>
        </div>

        <div class="reviews-strip">
          <div class="review-bubble">
            "Increíble anfitriona, todo perfecto ✨"
          </div>
          <div class="review-bubble">
            "Muy atenta y detallista, 100% recomendada"
          </div>
          <div class="review-bubble">
            "Nos sentimos en casa desde el primer momento"
          </div>
        </div>
      </div>

      <!-- Cards secundarias -->
      <div class="exp-side">
        <div class="exp-card exp-small">
          <div class="exp-icon-sm">💻</div>
          <h3 class="exp-role display" style="font-size:1.3rem;">
            Desarrolladora Web Freelance
          </h3>
          <p class="exp-company mono">
            Full Stack · Proyectos propios y de clientes
          </p>
          <p class="exp-desc">
            Diseño y desarrollo de sitios web en Astro, HTML/CSS y JavaScript.
            Especialidad en landing pages, portfolios y sitios para pymes y
            emprendedores. Proyectos activos: portfolio fotográfico, sitios de
            turismo, landings de servicios.
          </p>
          <div class="exp-tags">
            <span
              class="exp-tag mono"
              style="background:var(--neon);border-color:var(--neon-dim);"
              >Astro</span
            >
            <span class="exp-tag mono">HTML · CSS · JS</span>
            <span class="exp-tag">Diseño responsive</span>
            <span class="exp-tag">Freelance activo</span>
          </div>
        </div>

        <div class="exp-card exp-small exp-availability">
          <div class="avail-header">
            <span class="neon-tag">✦ Busco trabajo</span>
          </div>
          <h3
            class="display"
            style="font-size:1.4rem; color:var(--bark); margin: 1rem 0 0.5rem;"
          >
            ¿Qué ofrezco?
          </h3>
          <ul class="avail-list">
            <li>✓ Disponibilidad <strong>part-time</strong></li>
            <li>✓ Cobertura de <strong>francos</strong></li>
            <li>✓ <strong>Limpieza</strong> profesional</li>
            <li>✓ Flexibilidad horaria</li>
            <li>✓ Actitud proactiva y resolutiva</li>
            <li>✓ Experiencia comprobable en hospitalidad</li>
          </ul>
          <a
            href="#contacto"
            class="btn btn-primary"
            style="margin-top:1.5rem; width:100%; justify-content:center;"
          >
            Hablemos →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experiencia {
    background: var(--sand);
  }

  .exp-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  .exp-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
  }

  .exp-card-top {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .exp-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }
  .exp-icon-sm {
    font-size: 1.6rem;
    margin-bottom: 0.75rem;
  }

  .exp-role {
    font-size: 1.5rem;
    color: var(--bark);
    line-height: 1.2;
  }

  .exp-company {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 3px;
    letter-spacing: 0.05em;
  }

  .exp-rating {
    margin-left: auto;
    text-align: center;
    flex-shrink: 0;
  }
  .rating-num {
    font-size: 2rem;
    color: var(--amber);
    display: block;
    line-height: 1;
  }

  .exp-desc {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .exp-tag {
    font-size: 0.75rem;
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--bark);
    background: var(--sand);
  }

  /* Reviews */
  .reviews-strip {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .review-bubble {
    background: var(--sand);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.85rem;
    color: var(--bark);
    font-style: italic;
    border-left: 3px solid var(--amber);
  }

  /* Side cards */
  .exp-side {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .exp-small {
  }

  .exp-availability {
    background: var(--warm-dark);
    border-color: transparent;
    color: var(--sand);
  }

  .exp-availability .avail-header {
  }

  .avail-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: #c8b59a;
    margin-top: 0.5rem;
  }
  .avail-list strong {
    color: var(--neon);
  }

  .exp-availability .display {
    color: #e8a0a8 !important;
  }

  @media (max-width: 900px) {
    .exp-grid {
      grid-template-columns: 1fr;
    }
    .exp-card-top {
      flex-wrap: wrap;
    }
  }
</style>
