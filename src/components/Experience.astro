---

---

<section id="experiencia" class="section experiencia">
  <div class="container">
    <p class="section-label">Experiencia</p>
    <h2 class="section-title">
      Lo que traigo<br />a cada <span class="highlight">equipo.</span>
    </h2>
    <hr class="divider" />

    <!-- Fila superior: 2 cards -->
    <div class="exp-grid">
      <div class="exp-card exp-main">
        <div class="exp-card-top">
          <div class="exp-icon">🏡</div>
          <div>
            <h3 class="exp-role display">Superanfitriona Airbnb</h3>
            <p class="exp-company mono">Gestión propia · Airbnb</p>
          </div>
          <div class="exp-rating">
            <span class="rating-num display">4.92</span>
            <span class="mono" style="font-size:0.7rem; color:var(--muted);"
              >★ 62+ reseñas</span
            >
          </div>
        </div>
        <p class="exp-desc">
          Gestión integral de propiedad: atención al huésped, comunicación
          proactiva, mantenimiento, optimización de precios y calendario,
          resolución de imprevistos. Superanfitriona por consistencia en calidad
          y respuesta.
        </p>
        <div class="exp-tags">
          <span class="exp-tag">Atención al huésped</span>
          <span class="exp-tag">Gestión de reservas</span>
          <span class="exp-tag">Check-in / Check-out</span>
          <span class="exp-tag">Comunicación multicultural</span>
          <span class="exp-tag">Resolución de problemas</span>
        </div>
      </div>

      <div class="exp-card exp-small">
        <div class="exp-icon-sm">💻</div>
        <h3 class="exp-role display" style="font-size:1.3rem;">
          Desarrolladora Web Freelance
        </h3>
        <p class="exp-company mono">
          Full Stack · Proyectos propios y de clientes
        </p>
        <p class="exp-desc">
          Diseño y desarrollo de sitios web en Astro, HTML/CSS y JavaScript.
          Especialidad en landing pages, portfolios y sitios para pymes y
          emprendedores. Proyectos activos: portfolio fotográfico, sitios de
          turismo, landings de servicios.
        </p>
        <div class="exp-tags">
          <span
            class="exp-tag mono"
            style="background:var(--neon);border-color:var(--neon-dim);"
            >Astro</span
          >
          <span class="exp-tag mono">HTML · CSS · JS</span>
          <span class="exp-tag">Diseño responsive</span>
          <span class="exp-tag">Freelance activo</span>
        </div>
      </div>
    </div>

    <!-- Fila inferior: card marrón a ancho completo -->
    <div class="exp-card exp-availability exp-full">
      <div class="avail-inner">
        <div>
          <span class="neon-tag" style="font-size:0.95rem; padding: 6px 14px;"
            >✦ Busco trabajo</span
          >
          <h3
            class="display"
            style="font-size:2rem; color:#e8a0a8; margin: 1rem 0 0.5rem; line-height:1.2;"
          >
            ¿Qué ofrezco?
          </h3>
        </div>
        <ul class="avail-list">
          <li>✓ Disponibilidad <strong>part-time</strong></li>
          <li>✓ Cobertura de <strong>francos</strong></li>
          <li>✓ Flexibilidad horaria</li>
          <li>✓ Actitud proactiva y resolutiva</li>
          <li>✓ Experiencia comprobable en hospitalidad</li>
        </ul>
        <a
          href="#contacto"
          class="btn btn-primary"
          style="align-self:center; padding: 0.75rem 2.5rem;"
        >
          Hablemos →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .experiencia {
    background: var(--sand);
  }

  .exp-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    margin-top: 3rem;
    align-items: start;
  }

  .exp-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
  }

  .exp-card-top {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .exp-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }
  .exp-icon-sm {
    font-size: 1.6rem;
    margin-bottom: 0.75rem;
  }

  .exp-role {
    font-size: 1.5rem;
    color: var(--bark);
    line-height: 1.2;
  }

  .exp-company {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 3px;
    letter-spacing: 0.05em;
  }

  .exp-rating {
    margin-left: auto;
    text-align: center;
    flex-shrink: 0;
  }
  .rating-num {
    font-size: 2rem;
    color: var(--amber);
    display: block;
    line-height: 1;
  }

  .exp-desc {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .exp-tag {
    font-size: 0.75rem;
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--bark);
    background: var(--sand);
  }

  .exp-full {
    margin-top: 2rem;
  }

  .exp-availability {
    background: var(--warm-dark);
    border-color: transparent;
    color: var(--sand);
  }

  .avail-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  .avail-inner > div {
    flex: 1 1 200px;
  }

  .avail-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #c8b59a;
    flex: 1 1 220px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .avail-list strong {
    color: var(--neon);
  }

  .exp-availability .btn-primary:hover {
    background: var(--neon) !important;
    color: var(--warm-dark) !important;
  }

  @media (max-width: 900px) {
    .exp-grid {
      grid-template-columns: 1fr;
    }
    .exp-card-top {
      flex-wrap: wrap;
    }
    .avail-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .exp-availability .btn-primary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
